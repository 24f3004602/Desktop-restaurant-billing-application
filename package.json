{
  "name": "restaurant-pos",
  "version": "1.0.0",
  "description": "Restaurant billing desktop app with Electron and SQLite",
  "main": "main.js",
  "scripts": {
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "start": "npm run frontend:build && electron .",
    "dev": "concurrently -k \"npm run frontend:dev\" \"wait-on http://127.0.0.1:5173 && cross-env ELECTRON_START_URL=http://127.0.0.1:5173 electron .\"",
    "test": "node --test tests/**/*.test.js",
    "seed": "python scripts/seed.py",
    "backup": "bash scripts/backup.sh",
    "pack": "npm run frontend:build && electron-builder --dir",
    "dist": "npm run frontend:build && electron-builder --win nsis"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^34.3.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.casabenito.pos",
    "productName": "Casa Benito POS",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "frontend/dist/**/*",
      "backend/**/*",
      "electron/**/*",
      "database/**/*",
      "assets/**/*"
    ],
    "asarUnpack": [
      "backend/**/*"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
